{
  "name": "financial-loan-predictor",
  "version": "1.0.0",
  "description": "Loan Approval Prediction System using KNN and Random Forest",
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../ml && pip install -r requirements.txt",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "ml:train": "python ml/train_models.py",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "child_process": "^1.0.2",
    "concurrently": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.6.0",
    "multer": "^2.1.1"
  }
}
